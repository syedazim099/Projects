import java.lang.Math;

public class PromptBank {

    String[] questions;
    String[] statements;

    public PromptBank() {
        questions = new String[5];
        statements = new String[5];
    }

    public void populateStatementsArray() {
        statements[0] = "Tell me more about BLANK1 and BLANK2";
        statements[1] = "BLANK1 seems important to you, so does BLANK2. Please tell me more.";
        statements[2] = "BLANK1 and BLANK2 seem to be on your mind. Let's talk about it.";
        statements[3] = "What is the connection between BLANK1 and BLANK2 in your life?";
        statements[4] = "How do you feel about BLANK1 and BLANK2?";
    }

    public void populateQuestionsArray() {
        questions[0] = "Is there anything else about BLANK1 and BLANK2?";
        questions[1] = "Does BLANK1 bother you? How about BLANK2?";
        questions[2] = "Are BLANK1 and BLANK2 things you think about often?";
        questions[3] = "What do you associate with BLANK1 and BLANK2?";
        questions[4] = "Can you describe a situation where BLANK1 and BLANK2 were relevant?";
    }

    public String getRandomStatementTrunk() {
        int index = (int) (Math.random() * statements.length);
        return this.statements[index];
    }

    public String getRandomQuestionTrunk() {
        int index = (int) (Math.random() * questions.length);
        return this.questions[index];
    }

    public String createStatement(String word1, String word2) {
        String statementTemplate = getRandomStatementTrunk();
        return statementTemplate.replace("BLANK1", word1).replace("BLANK2", word2);
    }

    public String createQuestion(String word1, String word2) {
        String questionTemplate = getRandomQuestionTrunk();
        return questionTemplate.replace("BLANK1", word1).replace("BLANK2", word2);
    }

    public static void main(String[] args) {
        PromptBank eliza = new PromptBank();
        eliza.populateQuestionsArray();
        eliza.populateStatementsArray();

        String word1 = "happiness";
        String word2 = "stress";
        
        String questionReply = eliza.createQuestion(word1, word2);
        System.out.println(questionReply);
        
        String statementReply = eliza.createStatement(word1, word2);
        System.out.println(statementReply);
    }
}

    private void createCountGrid() {
        countGrid = new int[this.numRows][this.numColumns];
        for (int i = 0; i < countGrid.length; i++) {
            for (int j = 0; j < countGrid[i].length; j++) {
                this.countGrid[i][j] = 0;
                if (i == 0 && j == 0) { // top-left corner
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (i == this.bombGrid.length - 1 && j == 0) { // bottom-left
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (i == this.bombGrid.length - 1 && j == this.bombGrid[i].length - 1) { // bottom-right
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (i == 0 && j == this.bombGrid[i].length - 1) { // top-right
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (i == 0 && j > 0 && j < this.bombGrid[i].length - 1) { // top-side middle
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (j == 0 && i > 0 && i < this.bombGrid.length - 1) { // left-side middle
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (i == this.bombGrid.length - 1 && j > 0 && j < this.bombGrid[i].length - 1) { // bottom-side middle
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else if (j == this.bombGrid[i].length - 1 && i > 0 && i < this.bombGrid.length - 1) { // right-side middle
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                } else {
                    if (this.bombGrid[i][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i - 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j - 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j + 1] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i + 1][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                    if (this.bombGrid[i][j] == true) {
                        this.countGrid[i][j] += 1;
                    }
                }
            }
        }

    }

    private void createBombGrid() {
        int numBombsLeft = this.numBombs;
        bombGrid = new boolean[this.numRows][this.numColumns];
        for (int i = 0; i < bombGrid.length; i++) {
            for (int j = 0; j < bombGrid[i].length; j++) {
                bombGrid[i][j] = false;
            }
        }

        while (numBombsLeft > 0) {
            int randRow = (int) (Math.random() * numRows);
            int randCol = (int) (Math.random() * numColumns);
            if (bombGrid[randRow][randCol] == false) {
                bombGrid[randRow][randCol] = true;
                numBombsLeft -= 1;
            } else {
                continue;
            }
        }
    }

    public boolean[][] getBombGrid() {
        boolean[][] newBombgrid = new boolean[this.bombGrid.length][this.bombGrid[0].length];
        for (int i = 0; i < this.bombGrid.length; i++) {
            for (int j = 0; j < this.bombGrid[i].length; j++) {
                newBombgrid[i][j] = this.bombGrid[i][j];
            }
        }
        return newBombgrid;
    }

    public int[][] getCountGrid() {
        int[][] newCountgrid = new int[this.countGrid.length][this.countGrid[0].length];
        for (int i = 0; i < this.countGrid.length; i++) {
            for (int j = 0; j < this.countGrid[i].length; j++) {
                newCountgrid[i][j] = this.countGrid[i][j];
            }
        }
        return newCountgrid;
    }

